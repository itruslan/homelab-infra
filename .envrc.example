# Copy to .envrc and fill in your values.
# .envrc is gitignored — never commit it.

# Local module dev — uncomment to use local path instead of git source
# export MODULES_LOCAL_PATH=/Users/yourname/GitHub/terraform-modules

# Yandex Cloud
export YC_TOKEN=$(yc iam create-token)                      # requires yc cli
export YC_CLOUD_ID=""                                       # yc resource-manager cloud list

# Terraform state (Yandex Object Storage, S3-compatible)
export AWS_PROFILE=""                                       # aws cli profile with YC static keys
export TF_STATE_BUCKET=""                                   # bucket name

# Network
export DEFAULT_GATEWAY="192.168.99.1"
export DNS_SERVERS="192.168.99.1,8.8.8.8"                   # comma-separated
export DNS_DOMAIN="home.lab"
export VM_USERNAME="ubuntu"

# Proxmox
export PROXMOX_VE_ENDPOINT=""                               # https://pve-1.home.lab:8006
export PROXMOX_VE_USERNAME=root@pam                         # bootstrap only
export PROXMOX_VE_PASSWORD=""                               # bootstrap only, switch to API token after proxmox-svc apply
export PROXMOX_VE_API_TOKEN=""                              # user@realm!token=<secret>
export TF_VAR_ssh_public_key=""                             # ssh public key for VM cloud-init
